# ============================================================
#  Discord Bot — Environment Setup
# ============================================================
#
#  1. Rename this file from  .env.example  to  .env
#  2. Paste your bot token below (get it from Discord Developer Portal)
#  3. Run:  node bot.js
#
#  Get your token here:
#  https://discord.com/developers/applications
#  → Select your app → Bot → Reset Token → Copy
#
#  ⚠️  NEVER share your token or commit it to GitHub.
#      Anyone with your token can control your bot.
# ============================================================

DISCORD_BOT_TOKEN=paste_your_token_here

